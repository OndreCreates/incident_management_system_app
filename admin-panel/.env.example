# Identity server this admin panel talks to -- must be reachable from the BROWSER (it's the
# redirect target for /oauth2/authorize and the value baked into every token's `iss` claim).
IDENTITY_SERVER_ISSUER=http://localhost:9000

# Optional. Only needed when this server can't reach the identity server at the same address
# the browser uses -- e.g. in Docker Compose, where the browser needs "http://localhost:9000"
# but this container needs the service name "http://identity-server:9000". Defaults to
# IDENTITY_SERVER_ISSUER when unset, which is correct for plain local (non-Docker) dev.
# IDENTITY_SERVER_INTERNAL_URL=http://identity-server:9000

# Must exactly match the registered client in identity_server_app's oauth2_registered_client
OAUTH_CLIENT_ID=incident-admin-panel

# Must match INCIDENT_ADMIN_CLIENT_SECRET in identity_server_app's .env -- server-side only,
# never exposed to the browser (this app is a confidential client, not a public SPA client).
OAUTH_CLIENT_SECRET=incident-admin-dev-secret-change-me

# Must exactly match the redirect_uri registered for incident-admin-panel (incl. trailing slash / path)
OAUTH_REDIRECT_URI=http://localhost:3001/callback

# Where THIS SERVER reaches the incident_management_app backend API (server components /
# server actions only -- the access token never leaves this server).
INCIDENT_API_URL=http://localhost:8080
